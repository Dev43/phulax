# Phulax single-box deploy — copy to .env at the repo root and fill in.
# `docker compose up -d --build` reads .env automatically.
# ---------------------------------------------------------------------------

# Hostname Caddy serves on. Use the box's public DNS for production (so
# Let's Encrypt can issue a real cert). Leave as `localhost` for local
# bring-up — Caddy falls back to a self-signed cert.
PHULAX_HOST=localhost
CADDY_ADMIN_EMAIL=

# Postgres for KeeperHub. Defaults are fine for the hackathon; rotate before
# anything stays running long-term.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=keeperhub

# KeeperHub service-to-service keys. Any random string works — KH only needs
# the events/scheduler/MCP services to share the same value.
SCHEDULER_SERVICE_API_KEY=local-scheduler-key
MCP_SERVICE_API_KEY=local-mcp-key
EVENTS_SERVICE_API_KEY=local-events-key
KEEPERHUB_API_KEY=

# KeeperHub server-side secrets. Generate one for each slot:
#   openssl rand -hex 32
# All three are required — KH's instrumentation hook refuses to boot without them.
BETTER_AUTH_SECRET=
OAUTH_JWT_SECRET=
MCP_SESSION_SECRET=

# Phulax inference. HMAC key signs every classifier receipt — generate one:
#   openssl rand -hex 32
PHULAX_INFERENCE_HMAC_KEY=

# Phulax agent — connects to 0G Galileo testnet by default.
RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602
POOL_ADDRESS=0xb1DE7278b81e1Fd40027bDac751117AE960d8747
RISK_THRESHOLD=0.7

# 0G Storage Log endpoint + auth (optional — agent skips writes if blank).
OG_STORAGE_URL=
OG_STORAGE_AUTH=
