# Phulax web dashboard — built from the repo root so pnpm-workspace.yaml +
# lockfile are in scope. The basePath is baked at build time; pass via
# --build-arg NEXT_PUBLIC_BASE_PATH=/web (or whatever Caddy mounts it under).
#   docker build -f deploy/Dockerfile.web --build-arg NEXT_PUBLIC_BASE_PATH=/web -t phulax-web .

FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.12.3 --activate
WORKDIR /repo

FROM base AS deps
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY web/package.json web/package.json
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --filter @phulax/web...

FROM deps AS build
ARG NEXT_PUBLIC_BASE_PATH=""
ENV NEXT_PUBLIC_BASE_PATH=$NEXT_PUBLIC_BASE_PATH
COPY web/ web/
RUN pnpm --filter @phulax/web build

# Runner uses Next.js standalone output (web/next.config.mjs sets
# output: "standalone"). The standalone bundle ships everything needed —
# no node_modules COPY, no pnpm symlink dance.
FROM node:20-alpine AS runner
ENV NODE_ENV=production
WORKDIR /app
ARG NEXT_PUBLIC_BASE_PATH=""
ENV NEXT_PUBLIC_BASE_PATH=$NEXT_PUBLIC_BASE_PATH
# Standalone bundle. Next.js may emit server.js at /app/server.js (single-package
# detection) or /app/web/server.js (monorepo detection — keeps the workspace
# subpath). Mirror the static dir into both possible spots and let the CMD
# pick whichever server.js exists.
COPY --from=build /repo/web/.next/standalone ./
COPY --from=build /repo/web/.next/static ./.next/static
COPY --from=build /repo/web/.next/static ./web/.next/static
EXPOSE 3000
CMD ["sh", "-c", "if [ -f web/server.js ]; then exec node web/server.js; elif [ -f server.js ]; then exec node server.js; else echo 'no server.js found' && ls -la /app && exit 1; fi"]
