# Phulax web dashboard — built from the repo root so pnpm-workspace.yaml +
# lockfile are in scope. The basePath is baked at build time; pass via
# --build-arg NEXT_PUBLIC_BASE_PATH=/web (or whatever Caddy mounts it under).
#   docker build -f deploy/Dockerfile.web --build-arg NEXT_PUBLIC_BASE_PATH=/web -t phulax-web .

FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.12.3 --activate
WORKDIR /repo

FROM base AS deps
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY web/package.json web/package.json
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --filter @phulax/web...

FROM deps AS build
ARG NEXT_PUBLIC_BASE_PATH=""
ENV NEXT_PUBLIC_BASE_PATH=$NEXT_PUBLIC_BASE_PATH
COPY web/ web/
RUN pnpm --filter @phulax/web build

# Runner — fresh prod install gives a clean node_modules tree (no dangling
# pnpm .pnpm symlinks). Then drop in the .next build output. Skip Next.js
# standalone mode entirely — its monorepo + pnpm interactions are brittle
# (file-tracing misses next-bundled deps, server.js path moves around).
FROM base AS runner
ENV NODE_ENV=production
WORKDIR /app
ARG NEXT_PUBLIC_BASE_PATH=""
ENV NEXT_PUBLIC_BASE_PATH=$NEXT_PUBLIC_BASE_PATH
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY web/package.json web/package.json
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --prod --filter @phulax/web...
COPY --from=build /repo/web/.next web/.next
COPY --from=build /repo/web/next.config.mjs web/next.config.mjs
WORKDIR /app/web
EXPOSE 3000
CMD ["node_modules/.bin/next", "start", "-p", "3000"]
