# Phulax agent — built from the repo root so pnpm-workspace.yaml + lockfile
# are in scope. Run as:
#   docker build -f deploy/Dockerfile.agent -t phulax-agent .

FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.12.3 --activate
WORKDIR /repo

FROM base AS deps
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY agent/package.json agent/package.json
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --filter @phulax/agent...

FROM deps AS build
COPY agent/ agent/
RUN pnpm --filter @phulax/agent build

# Runner — fresh prod-only install against the same lockfile + package.json,
# so node_modules is a clean tree (no dangling pnpm symlinks from .pnpm in a
# different prefix). tsconfig emits to dist/src/index.js because include is
# ["src/**", "test/**"].
FROM base AS runner
ENV NODE_ENV=production
WORKDIR /app
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY agent/package.json agent/package.json
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --prod --filter @phulax/agent...
COPY --from=build /repo/agent/dist agent/dist
WORKDIR /app/agent
EXPOSE 8787
CMD ["node", "--enable-source-maps", "dist/src/index.js"]
