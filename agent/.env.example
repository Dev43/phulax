# 0G Galileo testnet (chain id 16602). Public RPC works; for the
# demo a private RPC with WSS is preferable so block subscriptions don't drop.
RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602

# Deployed contract addresses (Track B, see contracts/broadcast/.../run-latest.json).
POOL_ADDRESS=
PHULAX_ACCOUNT_ADDRESS=
PHULAX_ADAPTER_ADDRESS=
HUB_ADDRESS=
DEMO_ASSET_ADDRESS=

# Guardian hot key. MUST be the AGENT_ADDRESS that contracts/Deploy.s.sol
# registered. Single-selector authority: it can only call PhulaxAccount.withdraw.
# Fund it with a small amount of Galileo 0G for gas.
AGENT_PRIVATE_KEY=

# Detection wiring.
RISK_THRESHOLD=0.7
# Deployed inference server (Fly.io, stub mode until merged weights baked in).
# For local dev against `uvicorn server:app --reload`, use http://localhost:8000/classify.
CLASSIFIER_URL=https://phulax-inference.fly.dev/classify

# 0G Storage (KV for the exploit corpus, Log for incident receipts).
OG_STORAGE_URL=
OG_STORAGE_AUTH=
PHULAX_EXPLOIT_CORPUS_ROOT_HASH=
PHULAX_EXPLOIT_CORPUS_STREAM_ID=
PHULAX_INCIDENT_LOG_STREAM_ID=

# KeeperHub.
KEEPERHUB_URL=http://localhost:3000
KEEPERHUB_API_KEY=

# Server.
PORT=8787
