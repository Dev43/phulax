# 0G Galileo testnet (chain id 16602). Public RPC; explorer URL/key are
# only required when deploying with `--verify`.
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_EXPLORER_URL=https://chainscan-galileo.0g.ai/api
ZEROG_EXPLORER_API_KEY=

# Deployer hot key. MUST be funded with Galileo testnet 0G before
# `pnpm deploy:zerog`. Faucet: https://faucet.0g.ai
PRIVATE_KEY=

# Guardian agent address. Must be the same key the agent runtime signs
# withdraw() calls with. If left unset, the deploy script defaults to the
# deployer (fine for a smoke test, not for the recorded demo).
AGENT_ADDRESS=

# Optional: reuse an existing testnet ERC20 instead of deploying DemoAsset.
# Leave empty for a self-contained deploy.
DEMO_ASSET_ADDRESS=

# Optional: how many DemoAsset units the deploy script seeds into the pool
# as starting reserves. Default 100e18.
POOL_SEED_AMOUNT=
