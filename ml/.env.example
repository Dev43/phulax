# 0G Storage is on-chain (Flow contract + Indexer SDK), not an HTTP REST
# server, so the ml/ pipeline shells out to scripts/og.mjs which uses
# @0gfoundation/0g-ts-sdk with a plain ethers signer. See ml/og_client.py.
OG_PRIVATE_KEY=
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
OG_FLOW_ADDRESS=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
OG_CHAIN_ID=16602
# Optional: 32-byte hex stream id used by embed/index.py
OG_EXPLOIT_STREAM_ID=

OG_FT_ENDPOINT=
OG_FT_TOKEN=
LLAMA_CPP_DIR=
HF_HOME=
