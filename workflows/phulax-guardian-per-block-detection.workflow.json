          "endpoint": "http://agent:8787/decide",
          "httpBody": "{\"account\":\"0xA70060465c1cD280E72366082fE20C7618C18a66\",\"adapter\":\"0x0c39fF914e41DA07B815937ee70772ba21A5C760\",\"txHash\":\"{{@action-detect:Detect (tier 1/2/3).data.candidate.txHash}}\",\"ruleScore\":{{@action-detect:Detect (tier 1/2/3).data.candidate.ruleScore}},\"classifier\":{{@action-classify:Classify (tier 4 — 0G compute slot).data}}}",
          "actionType": "HTTP Request",
          "httpMethod": "POST",
          "httpHeaders": "{\"content-type\":\"application/json\"}"
        },
        "status": "idle"
      },
      "type": "action",
      "position": {
        "x": 1440,
        "y": 0
      }
    },
    {
      "id": "action-cond-fire",
      "data": {
        "type": "action",
        "label": "Fire?",
        "config": {
          "condition": "{{@action-decide:Decide (aggregate).data.fire}} == true",
          "actionType": "Condition"
        },
        "status": "idle"
      },
      "type": "action",
      "position": {
        "x": 1680,
        "y": 0
      }
    },
    {
      "id": "action-withdraw",
      "data": {
        "type": "action",
        "label": "PhulaxAccount.withdraw",
        "config": {
          "abi": "[{\"type\":\"function\",\"name\":\"withdraw\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"adapter\",\"type\":\"address\",\"internalType\":\"address\"}],\"outputs\":[{\"name\":\"\",\"type\":\"uint256\",\"internalType\":\"uint256\"}]}]",
          "network": "16602",
          "actionType": "web3/write-contract",
          "abiFunction": "withdraw",
          "functionArgs": "[\"0x0c39fF914e41DA07B815937ee70772ba21A5C760\"]",
          "contractAddress": "0xA70060465c1cD280E72366082fE20C7618C18a66",
          "priorityFeeGwei": "2"
        },
        "status": "idle"
      },
      "type": "action",
      "position": {
        "x": 1920,
        "y": 0
      }
    },
    {
      "id": "action-receipt",
      "data": {
        "type": "action",
        "label": "0G Storage receipt",
        "config": {
          "tag": "phulax.withdraw",
          "payload": "{\"event\":\"withdraw\",\"blockNumber\":\"{{@trigger-1:Block.blockNumber}}\",\"sourceTxHash\":\"{{@action-detect:Detect (tier 1/2/3).data.candidate.txHash}}\",\"score\":{{@action-decide:Decide (aggregate).data.score.value}},\"reason\":\"{{@action-decide:Decide (aggregate).data.reason}}\",\"withdrawTxHash\":\"{{@action-withdraw:PhulaxAccount.withdraw.transactionHash}}\",\"chainId\":16602}",
          "streamId": "REPLACE_WITH_RECEIPT_STREAM_ID",
          "actionType": "0g-storage/log-append"
        },
        "status": "idle"
      },
      "type": "action",
      "position": {
        "x": 2160,
        "y": 0
      }
    }
  ],
