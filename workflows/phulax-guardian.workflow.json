{
  "version": 1,
  "exportedAt": "2026-05-02T00:00:00.000Z",
  "workflow": {
    "name": "Phulax Guardian — Per-Block Detection",
    "description": "KeeperHub owns the loop. Every Galileo block: query pool Withdraw events → call our detector for tier-1/2/3 (http://localhost:8787, point this at wherever the agent service listens) → call inference for the classifier (https://phulax-inference.fly.dev — this step is the slot where 0G-served sealed inference plugs in once it serves our LoRA) → aggregate → conditional withdraw. PhulaxAccount.withdraw signed by the org wallet (the on-chain `agent` role); contract hard-locks recipient = owner. Receipt streamId is REPLACE_WITH_RECEIPT_STREAM_ID — provision via 0g-storage/log-append once before first run."
  },
  "nodes": [
    {
      "id": "trigger-1",
      "type": "trigger",
      "position": { "x": 0, "y": 0 },
      "data": {
        "label": "Block",
        "type": "trigger",
        "config": {
          "triggerType": "Block",
          "network": "16602",
          "blockInterval": "1"
        }
      }
    },
    {
      "id": "action-query",
      "type": "action",
      "position": { "x": 240, "y": 0 },
      "data": {
        "label": "Query Pool Withdraws",
        "type": "action",
        "config": {
          "actionType": "web3/query-events",
          "network": "16602",
          "contractAddress": "0xb1DE7278b81e1Fd40027bDac751117AE960d8747",
          "abi": "[{\"type\":\"event\",\"name\":\"Withdraw\",\"anonymous\":false,\"inputs\":[{\"name\":\"reserve\",\"type\":\"address\",\"indexed\":true},{\"name\":\"user\",\"type\":\"address\",\"indexed\":true},{\"name\":\"to\",\"type\":\"address\",\"indexed\":true},{\"name\":\"amount\",\"type\":\"uint256\",\"indexed\":false}]}]",
          "eventName": "Withdraw",
          "fromBlock": "{{@trigger-1:Block.blockNumber}}",
          "toBlock": "{{@trigger-1:Block.blockNumber}}"
        }
      }
    },
    {
      "id": "action-cond-has-txs",
      "type": "action",
      "position": { "x": 480, "y": 0 },
      "data": {
        "label": "Has matching events?",
        "type": "action",
        "config": {
          "actionType": "Condition",
          "condition": "{{@action-query:Query Pool Withdraws.eventCount}} > 0"
        }
      }
    },
    {
      "id": "action-detect",
      "type": "action",
      "position": { "x": 720, "y": 0 },
      "data": {
        "label": "Detect (tier 1/2/3)",
        "type": "action",
        "config": {
          "actionType": "HTTP Request",
          "endpoint": "http://localhost:8787/detect-features",
          "httpMethod": "POST",
          "httpHeaders": "{\"content-type\":\"application/json\"}",
          "httpBody": "{\"account\":\"0xA70060465c1cD280E72366082fE20C7618C18a66\",\"adapter\":\"0x0c39fF914e41DA07B815937ee70772ba21A5C760\",\"events\":{{@action-query:Query Pool Withdraws.events}}}"
        }
      }
    },
    {
      "id": "action-cond-has-candidate",
      "type": "action",
      "position": { "x": 960, "y": 0 },
      "data": {
        "label": "Has candidate?",
        "type": "action",
        "config": {
          "actionType": "Condition",
          "condition": "{{@action-detect:Detect (tier 1/2/3).hasCandidate}} == true"
        }
      }
    },
    {
      "id": "action-classify",
      "type": "action",
      "position": { "x": 1200, "y": 0 },
      "data": {
        "label": "Classify (tier 4 — 0G compute slot)",
        "type": "action",
        "config": {
          "actionType": "HTTP Request",
          "endpoint": "https://phulax-inference.fly.dev/classify",
          "httpMethod": "POST",
          "httpHeaders": "{\"content-type\":\"application/json\"}",
          "httpBody": "{{@action-detect:Detect (tier 1/2/3).classifierInput}}"
        }
      }
    },
    {
      "id": "action-decide",
      "type": "action",
      "position": { "x": 1440, "y": 0 },
      "data": {
        "label": "Decide (aggregate)",
        "type": "action",
        "config": {
          "actionType": "HTTP Request",
          "endpoint": "http://localhost:8787/decide",
          "httpMethod": "POST",
          "httpHeaders": "{\"content-type\":\"application/json\"}",
          "httpBody": "{\"account\":\"0xA70060465c1cD280E72366082fE20C7618C18a66\",\"adapter\":\"0x0c39fF914e41DA07B815937ee70772ba21A5C760\",\"txHash\":\"{{@action-detect:Detect (tier 1/2/3).candidate.txHash}}\",\"ruleScore\":{{@action-detect:Detect (tier 1/2/3).candidate.ruleScore}},\"classifier\":{{@action-classify:Classify (tier 4 — 0G compute slot)}}}"
        }
      }
    },
    {
      "id": "action-cond-fire",
      "type": "action",
      "position": { "x": 1680, "y": 0 },
      "data": {
        "label": "Fire?",
        "type": "action",
        "config": {
          "actionType": "Condition",
          "condition": "{{@action-decide:Decide (aggregate).fire}} == true"
        }
      }
    },
    {
      "id": "action-withdraw",
      "type": "action",
      "position": { "x": 1920, "y": 0 },
      "data": {
        "label": "PhulaxAccount.withdraw",
        "type": "action",
        "config": {
          "actionType": "web3/write-contract",
          "network": "16602",
          "contractAddress": "0xA70060465c1cD280E72366082fE20C7618C18a66",
          "abi": "[{\"type\":\"function\",\"name\":\"withdraw\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"adapter\",\"type\":\"address\",\"internalType\":\"address\"}],\"outputs\":[{\"name\":\"\",\"type\":\"uint256\",\"internalType\":\"uint256\"}]}]",
          "abiFunction": "withdraw",
          "functionArgs": "[\"0x0c39fF914e41DA07B815937ee70772ba21A5C760\"]",
          "priorityFeeGwei": "2"
        }
      }
    },
    {
      "id": "action-receipt",
      "type": "action",
      "position": { "x": 2160, "y": 0 },
      "data": {
        "label": "0G Storage receipt",
        "type": "action",
        "config": {
          "actionType": "0g-storage/log-append",
          "streamId": "REPLACE_WITH_RECEIPT_STREAM_ID",
          "payload": "{\"event\":\"withdraw\",\"blockNumber\":\"{{@trigger-1:Block.blockNumber}}\",\"sourceTxHash\":\"{{@action-detect:Detect (tier 1/2/3).candidate.txHash}}\",\"score\":{{@action-decide:Decide (aggregate).score.value}},\"reason\":\"{{@action-decide:Decide (aggregate).reason}}\",\"withdrawTxHash\":\"{{@action-withdraw:PhulaxAccount.withdraw.transactionHash}}\",\"chainId\":16602}",
          "tag": "phulax.withdraw"
        }
      }
    }
  ],
  "edges": [
    { "id": "e-1", "source": "trigger-1", "target": "action-query", "type": "animated" },
    { "id": "e-2", "source": "action-query", "target": "action-cond-has-txs", "type": "animated" },
    { "id": "e-3", "source": "action-cond-has-txs", "target": "action-detect", "type": "animated" },
    { "id": "e-4", "source": "action-detect", "target": "action-cond-has-candidate", "type": "animated" },
    { "id": "e-5", "source": "action-cond-has-candidate", "target": "action-classify", "type": "animated" },
    { "id": "e-6", "source": "action-classify", "target": "action-decide", "type": "animated" },
    { "id": "e-7", "source": "action-decide", "target": "action-cond-fire", "type": "animated" },
    { "id": "e-8", "source": "action-cond-fire", "target": "action-withdraw", "type": "animated" },
    { "id": "e-9", "source": "action-withdraw", "target": "action-receipt", "type": "animated" }
  ],
  "integrationBindings": []
}
